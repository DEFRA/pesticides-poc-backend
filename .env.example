# Local environment variables for development.
#
# Copy this file to `.env` (`cp .env.example .env`) before running the app
# locally. The file can be left empty — it only needs to exist, because the
# dev script runs `node --watch --env-file-if-exists=.env` and `--watch`
# fails with ENOENT if the .env file is missing.
#
# Uncomment and adjust any of the values below to override the defaults in
# src/config.js for your local environment.

# PORT=3001
# MONGO_URI=mongodb://127.0.0.1:27017/
